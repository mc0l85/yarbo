# Yarbo daemon — copy to ~/McKay/.env and fill in values
# All runtime secrets live in ~/McKay/.env (mode 600). Never commit values here.

# MQTT broker (Yarbo base station — verify MAC during commissioning)
YARBO_MQTT_HOST=10.50.0.182
YARBO_MQTT_PORT=1883

# Yarbo portal — used ONLY for initial cookie-generation script
# Runtime auth uses ~/.yarbo/portal_session.json (Playwright cookie persistence)
YARBO_PORTAL_USER=
YARBO_PORTAL_PASS=
YARBO_PORTAL_TICKETS_URL=https://support.yarbo.com/portal/en/myarea?viewId=905108000000240047&sortBy=recentThread

# MBP Bridge (Android emulator gateway on Charlotte's Mac)
MBP_BRIDGE_URL=http://myrons-mbp.local:5055
MBP_BRIDGE_TOKEN=

# LLM proxy (claude-cli-proxy on x404)
CLAUDE_PROXY_URL=http://localhost:7430
CLAUDE_PROXY_BRAIN_PATH=/brain

# Alert egress (iMessage via _IMESSAGE skill)
IMESSAGE_ALERT_RECIPIENT=

# GWS MSE SSH relay (dummy host for gws-mse CLI)
GWS_SSH_HOST=dummy
GWS_MSE_IDENTITY=

# Daemon host
YARBO_DAEMON_HOST=10.0.17.249

# Cases staging + Jarvis mount
YARBO_CASES_STAGE_DIR=/home/mckay/.yarbo/cases-stage
YARBO_CASES_JARVIS_DIR=/home/mckay/mnt/jarvis-projects/yarbo/CASES
